// Copy this file to Secrets.xcconfig and replace with your real values. Do not commit Secrets.xcconfig.
SUPABASE_URL = https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY = YOUR_ANON_KEY

// Inject into Info.plist at build time
INFOPLIST_KEY_SUPABASE_URL = $(SUPABASE_URL)
INFOPLIST_KEY_SUPABASE_ANON_KEY = $(SUPABASE_ANON_KEY)
