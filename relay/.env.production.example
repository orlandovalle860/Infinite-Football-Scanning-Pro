# Copy to .env on the server or set in systemd / Docker / hosting panel.
# See README.md → Production (VPS + TLS).

# Port the Node process listens on (behind reverse proxy, use 127.0.0.1 + a high port or only localhost).
PORT=3000

# Bind address. Use 127.0.0.1 if only the local reverse proxy connects; 0.0.0.0 for direct LAN tests.
HOST=127.0.0.1

# Public WebSocket URL returned in JSON (wss in production). Must end up as .../ws after normalization.
# Example behind TLS:
PUBLIC_WS_URL=wss://relay.yourdomain.com/ws

# Optional tuning (defaults are fine for most deployments)
# ROOM_TTL_MS=86400000
# EMPTY_ROOM_GRACE_MS=300000
